{
  "name": "Kotlin",
  "scopeName": "source.kotlin",
  "fileTypes": [
    "kt",
    "kts"
  ],
  "patterns": [
    {
      "match": "\\b(fun|class|interface|object|val|var|const|lateinit|if|else|when|return|true|false|null|import|package|suspend|coroutine)\\b",
      "name": "keyword.kotlin"
    },
    {
      "match": "\".*?\"",
      "name": "string.quoted.double.kotlin"
    },
    {
      "match": "\\b[0-9]+\\b",
      "name": "constant.numeric.kotlin"
    },
    {
      "match": "//.*$",
      "name": "comment.line.double-slash.kotlin"
    },
    {
      "begin": "/\\*",
      "end": "\\*/",
      "name": "comment.block.kotlin"
    },
    {
      "match": "\\b([A-Z][a-zA-Z0-9_]*)\\b",
      "name": "entity.name.class.kotlin"
    },
    {
      "match": "\\b([a-z][a-zA-Z0-9_]*)\\s*(?=\\()",
      "name": "entity.name.function.kotlin"
    }
  ]
}